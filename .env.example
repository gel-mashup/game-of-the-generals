# Server configuration
PORT=3001

# CORS origin - must match the client URL in production
# Development: http://localhost:3000
# Production: https://your-client-domain.com
CORS_ORIGIN=http://localhost:3000

# Node environment
NODE_ENV=production

# Client (Next.js) - must be available at docker build time
# This URL must match the server's actual network address
NEXT_PUBLIC_API_URL=http://server:3001
